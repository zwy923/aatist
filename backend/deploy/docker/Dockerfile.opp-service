# Dockerfile for opp-service
FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o opp-service ./cmd/opp-service

FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /app
COPY --from=builder /app/opp-service .
COPY --from=builder /app/configs ./configs
COPY --from=builder /app/migrations ./migrations
ENV SERVICE_NAME=opp-service
CMD ["./opp-service"]

