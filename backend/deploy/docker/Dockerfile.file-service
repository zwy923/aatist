# Dockerfile for file-service
FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o file-service ./cmd/file-service

FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /app
COPY --from=builder /app/file-service .
COPY --from=builder /app/configs ./configs
ENV SERVICE_NAME=file-service
CMD ["./file-service"]

