# Dockerfile for ai-worker (placeholder - TODO: implement)
FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o ai-worker ./cmd/ai-worker

FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /app
COPY --from=builder /app/ai-worker .
COPY --from=builder /app/configs ./configs
ENV SERVICE_NAME=ai-worker
CMD ["./ai-worker"]
