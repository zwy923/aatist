# =====================================================
# Aatist Project .gitignore (Go + React + Docker)
# =====================================================

# ------------------------------
# Environment
# ------------------------------
.env
.env.*
!.env.example

# ------------------------------
# Go
# ------------------------------
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
/go/pkg/
/go/bin/
/go/build/
/bin/
/pkg/
/obj/
*.modcache/

# ------------------------------
# Frontend (React/Vite)
# ------------------------------
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/build/

# ------------------------------
# Docker / Compose
# ------------------------------
*.pid
*.tar
*.bak
*.tmp
*.old
*.lock
Dockerfile~
docker-compose.override.yml
docker-data/
data/
tmp/
*.sock

# ------------------------------
# Logs & cache
# ------------------------------
*.log
*.out
*.tmp
*.bak
.DS_Store
*.swp
.cache/
*.sqlite3
*.db

# ------------------------------
# System / IDE / Editor
# ------------------------------
.vscode/
.idea/
*.iml
*.sublime-project
*.sublime-workspace
*.code-workspace
Thumbs.db
.DS_Store

# ------------------------------
# Secrets
# ------------------------------
secrets.json
credentials.json
service_account.json
private_key.pem
id_rsa
id_rsa.pub
*.crt
*.key

# ------------------------------
# Tests / Reports
# ------------------------------
.coverage
htmlcov/
nosetests.xml
coverage.xml
*.coverage
*.pytest_cache/
.pytest_cache/
reports/
test_results/

postman/
.postman/
